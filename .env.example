# Source language (ISO 639-1) or "auto"
SOURCE_LANG=auto

# Target language — Georgian
TARGET_LANG=ka

# Google Cloud Translation (one of the following):
# Path to service-account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Or API key (if your key is in GOOGLE_APPLICATION_CREDENTIALS, the script auto-detects AIza... keys):
# GOOGLE_TRANSLATE_API_KEY=

# Native pipeline input/output
INPUT_HTML=data/html/document.html
PARAGRAPH_GAP_MIN=18
PARAGRAPH_GAP_MAX=400
PDF_FORMAT=A4
PRINT_BACKGROUND=true

# Proportional line distribution (step html)
LENGTH_RATIO_THRESHOLD=1.8
FONT_SCALE_MIN=0.85
GEORGIAN_WIDTH_FACTOR=1.05
WRAP_SAFETY_FACTOR=0.92
PAGE_SIDE_MARGIN=

# pdf2htmlEX (Docker step only)
PDF2HTML_ZOOM=1.3
